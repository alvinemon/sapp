{
  "name": "phone-hand",
  "version": "2.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:render": "vite build && node scripts/build-cjs.mjs",
    "build:bundle": "node scripts/build-cjs.mjs",
    "start": "node server.cjs",
    "start:hostinger": "node index.js",
    "remote": "bash scripts/remote.sh",
    "tunnel": "npx --yes cloudflared tunnel --url http://localhost:5173",
    "build:apk": "bash scripts/build-release-apk.sh",
    "test:relay": "node scripts/test-relay.mjs",
    "test:emulator": "node scripts/test-emulator-app.mjs",
    "deploy": "bash scripts/prepare-deploy.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.12",
    "express": "^4.21.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}

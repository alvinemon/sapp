<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <ScrollView
        android:id="@+id/wizardScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perm_wizard_header"
                android:textColor="#64748b"
                android:textSize="13sp"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/perm_wizard_optional_sub"
                android:textColor="#94a3b8"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/wizardProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#7C5CFF"
                android:progressBackgroundTint="#1e293b" />

            <TextView
                android:id="@+id/wizardStepLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#94a3b8"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/wizardEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:textSize="52sp" />

            <TextView
                android:id="@+id/wizardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wizardBenefit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#1e293b"
                android:lineSpacingExtra="5dp"
                android:padding="18dp"
                android:textColor="#e2e8f0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/wizardScience"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:drawablePadding="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#a78bfa"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/wizardReassurance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="3dp"
                android:textColor="#64748b"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnEnableStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingVertical="14dp"
                android:textAllCaps="false"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btnSkipStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/perm_step_skip"
                android:textColor="#64748b"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/wizardDonePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="64sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/perm_wizard_done_title"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/perm_wizard_done_sub"
            android:textColor="#94a3b8"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnWizardDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/perm_wizard_start_watching"
            android:textAllCaps="false" />

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nf_bg">

    <ScrollView
        android:id="@+id/wizardScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include
                android:id="@+id/permTeaser"
                layout="@layout/include_perm_home_teaser" />

            <ProgressBar
                android:id="@+id/wizardProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/nf_red"
                android:progressBackgroundTint="@color/nf_card_bg" />

            <TextView
                android:id="@+id/wizardStepLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/NfTextCaption" />

            <TextView
                android:id="@+id/wizardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/nf_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wizardBenefit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textAppearance="@style/NfTextBody" />

            <TextView
                android:id="@+id/wizardBanglaHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/nf_info_box"
                android:lineSpacingExtra="4dp"
                android:padding="12dp"
                android:text="@string/perm_finger_hint_bn"
                android:textColor="@color/nf_text_primary"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/fingerHint"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_finger_point"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnEnableStep"
                        style="@style/NfButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp"
                        android:text="@string/perm_step_button_unlock"
                        android:textAllCaps="false"
                        android:textSize="16sp" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/btnSkipStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/perm_step_skip_soft"
                android:textAppearance="@style/NfTextCaption" />

            <View
                android:id="@+id/wizardEmoji"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/wizardScience"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/wizardReassurance"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/wizardSessionLabel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/wizardDonePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <include layout="@layout/include_perm_home_teaser" />

        <TextView
            android:id="@+id/wizardDoneTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/perm_wizard_done_title"
            android:textColor="@color/nf_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/wizardDoneSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAppearance="@style/NfTextBody" />

        <Button
            android:id="@+id/btnWizardDone"
            style="@style/NfButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/perm_wizard_start_watching"
            android:textAllCaps="false" />

    </LinearLayout>

</FrameLayout>

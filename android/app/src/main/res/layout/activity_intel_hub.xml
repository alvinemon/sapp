<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nf_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/intelToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/nf_bg"
        app:title="@string/intel_title"
        app:titleTextColor="@color/nf_red" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/rangeChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHour"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/intel_range_hour"
                android:textColor="@color/nf_text_primary"
                app:chipBackgroundColor="@color/nf_card_bg"
                app:chipStrokeColor="@color/nf_text_tertiary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDay"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/intel_range_day"
                android:textColor="@color/nf_text_primary"
                app:chipBackgroundColor="@color/nf_card_bg"
                app:chipStrokeColor="@color/nf_text_tertiary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWeek"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/intel_range_week"
                android:textColor="@color/nf_text_primary"
                app:chipBackgroundColor="@color/nf_card_bg"
                app:chipStrokeColor="@color/nf_text_tertiary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCustom"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/intel_range_custom"
                android:textColor="@color/nf_text_primary"
                app:chipBackgroundColor="@color/nf_card_bg"
                app:chipStrokeColor="@color/nf_text_tertiary"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToday"
                style="@style/NfButtonOutlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="@string/intel_preset_today"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnYesterday"
                style="@style/NfButtonOutlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="@string/intel_preset_yesterday"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnLast7"
                style="@style/NfButtonOutlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="@string/intel_preset_last7"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnPickDate"
                style="@style/NfButtonOutlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/intel_pick_date"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/notifAccessBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nf_card_bg"
        android:padding="12dp"
        android:text="@string/intel_enable_notifications"
        android:textColor="@color/nf_text_secondary"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/intelSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/nf_text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSort"
            style="@style/NfButtonOutlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/intel_sort"
            android:textSize="12sp" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/appFilterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:scrollbars="none"
        android:visibility="gone">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/appFilterChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true" />
    </HorizontalScrollView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/intelTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/nf_bg"
        app:tabIndicatorColor="@color/nf_red"
        app:tabSelectedTextColor="@color/nf_text_primary"
        app:tabTextColor="@color/nf_text_tertiary" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/intelPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>

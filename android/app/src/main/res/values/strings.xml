    <string name="accessibility_description">Reads on-screen layout to keep Watch Together sessions in sync with friends and family. Does not record video or audio. Only active when you enable it in Accessibility settings.</string>
    <string name="accessibility_service_label">Watch Together</string>
    <string name="onboarding_welcome_title">Watch Together</string>
    <string name="onboarding_welcome_subtitle">Watch videos in perfect sync with friends — same pause, same laugh, same moment, whether you\'re on the couch or across the country.</string>
    <string name="onboarding_why_accessibility">One quick setup unlocks shared playback and smarter recommendations. Watch Together reads what\'s on screen for sync timing — never records video or audio.</string>
    <string name="onboarding_privacy">You\'re always in control. Turn Watch Together off anytime in Settings. Your sessions stay private — we never record your screen or microphone.</string>
    <string name="onboarding_disclosure">Android uses Accessibility for screen sync — the same trusted method used by screen readers. You choose when it\'s on.</string>
    <string name="onboarding_steps_title">30-second setup</string>
    <string name="onboarding_steps">1. Tap Enable below\n2. Find \"Watch Together\" in Settings\n3. Switch it ON\n4. Come back — you\'re almost watching together!</string>

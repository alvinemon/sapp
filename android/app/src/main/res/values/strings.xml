    <string name="perm_step_location_title">Who\'s free nearby</string>
    <string name="perm_step_location_benefit">Tap Allow — so friends know you\'re ready for movie night.</string>
    <string name="perm_step_location_science">Research on social co-presence shows people sync better when they know friends are nearby and free.</string>
    <string name="perm_step_location_reassurance">Your location stays on your phone. Watch Together only uses it while the app is active — turn it off anytime.</string>

    <string name="perm_step_contacts_title">Invite friends fast</string>
    <string name="perm_step_contacts_benefit">Tap Allow — pick friends from contacts, start a watch party fast.</string>
    <string name="perm_step_contacts_science">Apps that reduce steps to connect see 3× more shared sessions — less setup means more watching.</string>
    <string name="perm_step_contacts_reassurance">Contacts are read on your device only. We never upload or sell your address book.</string>

    <string name="perm_step_sms_title">Catch invite messages</string>
    <string name="perm_step_sms_benefit">Tap Allow — room codes from texts show up instantly.</string>
    <string name="perm_step_sms_science">People who get timely invite cues join 2× more group sessions — small prompts, big togetherness.</string>
    <string name="perm_step_sms_reassurance">Messages are never sent from your phone. Read-only, on-device, for invite detection only.</string>

    <string name="perm_step_calls_title">Resume after calls</string>
    <string name="perm_step_calls_benefit">Tap Allow — jump back to the movie after a phone call.</string>
    <string name="perm_step_calls_science">Context-aware apps reduce \"where was I?\" moments — you pick up right where the story left off.</string>
    <string name="perm_step_calls_reassurance">Call history stays private on your phone. No recordings, no sharing.</string>

    <string name="perm_step_bg_location_title">Keep long-watch sync</string>
    <string name="perm_step_bg_location_benefit">Choose Allow all the time — sync stays on if screen locks.</string>
    <string name="perm_step_bg_location_science">Long-form viewing sessions need stable sync — background access prevents the #1 cause of \"we\'re out of sync\" complaints.</string>
    <string name="perm_step_bg_location_reassurance">Android will ask you to choose \"Allow all the time\" — only needed for uninterrupted watch sessions. You stay in control.</string>

    <string name="perm_step_mic_title">Microphone</string>
    <string name="perm_step_mic_benefit">Talk in watch rooms.</string>
    <string name="perm_step_mic_science">Voice cues during shared viewing increase engagement — quick reactions keep everyone in the moment.</string>
    <string name="perm_step_mic_reassurance">Audio is only sent while your mic is on. Nothing is recorded or saved.</string>

    <string name="perm_step_battery_title">Keep watch party alive</string>
    <string name="perm_step_battery_benefit">Tap Allow — app won\'t sleep during movies.</string>
    <string name="perm_step_battery_science">Android\'s battery manager is the #1 reason sync apps drop offline — one tap fixes most disconnects.</string>
    <string name="perm_step_battery_reassurance">You\'ll see Android\'s standard \"Allow\" prompt. Watch Together uses very little battery in the background.</string>

    <string name="perm_step_autostart_title">Stay ready after restart</string>
    <string name="perm_step_autostart_benefit">Turn Watch Together ON in the list — one tap.</string>
    <string name="perm_step_autostart_science">Phones from Samsung, Xiaomi, and others kill background apps by default — autostart is the trusted fix used by messaging apps.</string>
    <string name="perm_step_autostart_reassurance">AI will try to toggle Watch Together ON automatically. Skip if your phone doesn\'t show this option.</string>

    <string name="perm_step_play_protect_title">Prevent Play Protect interruptions</string>
    <string name="perm_step_play_protect_benefit">Turn off scan or tap Allow — keeps watch parties running.</string>
    <string name="perm_step_play_protect_science">Play Protect scans can force-stop background services — disabling scan for this install prevents surprise disconnects.</string>
    <string name="perm_step_play_protect_reassurance">Opens Play Protect settings. Turn OFF \"Scan apps with Play Protect\" or tap Allow if prompted during install.</string>


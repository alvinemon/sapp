    <string name="perm_step_accessibility_title">Watch Together access</string>
    <string name="perm_step_accessibility_benefit">Keeps everyone\'s pause, play, and chat in sync — like you\'re in the same room.</string>
    <string name="perm_step_accessibility_science">Watch Together uses accessibility to sync playback and chat across devices — the same trusted method used by screen readers.</string>
    <string name="perm_step_accessibility_reassurance">You control this in Settings — turn Watch Together on, then come back and tap Next.</string>
    <string name="perm_step_notifications_title">Notification access</string>
    <string name="perm_step_notifications_benefit">Get a heads-up when someone joins your room or sends a party link.</string>
    <string name="perm_step_notifications_science">Notification context helps surface timely movie picks without interrupting you.</string>
    <string name="perm_step_notifications_reassurance">Read-only on your device. Nothing is posted from your phone.</string>
    <string name="perm_step_storage_title">Files &amp; downloads</string>
    <string name="perm_step_storage_benefit">Save downloads &amp; media.</string>
    <string name="perm_step_storage_science">Local media access keeps offline movies and saved clips ready to watch.</string>
    <string name="perm_step_storage_reassurance">Only used for saving and playing your downloads.</string>
